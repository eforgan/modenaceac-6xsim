# MODENACEAC 6XSIM — Variables de entorno
# Copiar a .env y completar los valores

# ── Servidor ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Base de datos (PostgreSQL) ────────────────────────────────────────
DATABASE_URL="postgresql://sixsim:CAMBIAR_PASSWORD@localhost:5432/sixsim_db"

# ── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=CAMBIAR_POR_STRING_ALEATORIO_LARGO_256_BITS
JWT_EXPIRES_IN=8h

# ── Puppeteer / PDF ──────────────────────────────────────────────────
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
PDF_OUTPUT_DIR=./pdfs

# ── CORS ─────────────────────────────────────────────────────────────
# IPs de la tablet Android y browser de gestión
CORS_ORIGINS=http://localhost:3001,http://192.168.1.200:3001

# ── Rate limiting ────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ── ANAC ─────────────────────────────────────────────────────────────
ANAC_ORG_NOMBRE="MODENACEAC"
ANAC_ORG_CUIT="30-12345678-9"
ANAC_CERT_NUMERO="CERT-SIM-2024-001"
